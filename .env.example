# Copy to .env, fill in real values, then `set -a && source .env && set +a`
# (linux/mac) or use a launcher that loads it (windows). values here are
# documentation only — do not commit a real .env.

# --- Notifications relay ---

# REQUIRED: the chat id the relay uses for your target group. ask whoever
# runs the relay if you don't know it. without this set, notify_telegram_group
# will throw on first call.
NOTIFY_CHAT_ID=-5100088425

# Optional: relay endpoint. defaults to the eagle3dstreaming production relay.
# override only for staging/testing.
# NOTIFY_URL=https://notifications.eagle3dstreaming.com/message_sent

# --- Scraper pacing ---

# Delay between sequential video-page fetches in milliseconds. default 60000
# (1 min) — humans-clicking-through cadence. lower for faster CLI testing.
# YT_SCRAPE_INTER_DELAY_MS=60000

# Wait before the single retry-after-429. default 6000 (6s). lower for tests.
# YT_SCRAPE_RETRY_MS=6000

# --- Standalone CLI only (not used by the plugin in production) ---

# Where `node dist/cli.js --status ...` persists state. Has NO effect on the
# plugin running inside OpenClaw — that path comes from openclaw.json's
# agents.defaults.workspace.
#
# Default: ~/.openclaw/workspace (linux/mac) or %USERPROFILE%\.openclaw\workspace (windows).
# Override only for sandboxed test runs of the CLI:
#   linux/mac:  YT_WORKSPACE=/tmp/yt-test
#   windows:    YT_WORKSPACE=C:\temp\yt-test
