# local test config — copy to .env and fill in real values.
# .env is gitignored; never commit it.

# Telegram bot token from @BotFather. setting this enables direct Bot API mode
# (skips the eagle3dstreaming relay).
TELEGRAM_BOT_TOKEN=1234567890:AAH-replace-with-your-bot-token

# chat id of your test channel or group (negative for groups/channels,
# starts with -100 for channels). get it from:
#   https://api.telegram.org/bot<TOKEN>/getUpdates
NOTIFY_CHAT_ID=-1001234567890

# YouTube channel to monitor. UC-id or @handle, both work.
YT_CHANNEL=@eagle3dstreaming

# how many videos to track. "all" = every video on the channel's /videos tab.
# for local testing, start with a small number to keep runs short.
YT_MAX_VIDEOS=3

# unused when YT_VIEWS_ONLY=true; pacing for the legacy per-video page mode.
YT_SCRAPE_INTER_DELAY_MS=8000

# views-only = no per-video page fetches; views come from /videos tab json.
YT_VIEWS_ONLY=true

# mixerno (primary) or livecounts (fallback); unset → rounded HTML count.
YT_SUBSCRIBER_SOURCE=mixerno

# workspace for state. defaults to ~/.openclaw/workspace if unset; override
# to keep local-test state separate from production.
YT_WORKSPACE=./local-test/workspace

# Gemini API key. used only by gemini-tool-test.mjs (not by cron-runner).
# get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=AIza-replace-with-your-key
